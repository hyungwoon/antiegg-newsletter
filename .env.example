# Ghost Admin API (square.antiegg.kr)
# Ghost 관리자 → Settings → Integrations → Custom Integration
# 형식: {id}:{secret}
GHOST_API_URL=https://square.antiegg.kr
GHOST_ADMIN_API_KEY=

# WordPress REST API (antiegg.kr)
# WP 관리자 → 사용자 → 프로필 → 애플리케이션 비밀번호
WP_API_URL=https://antiegg.kr
WP_USERNAME=
WP_APP_PASSWORD=

# Stibee (뉴스레터 발송)
STIBEE_API_KEY=
STIBEE_LIST_ID=85471
STIBEE_LIST_ID_TEST=237526

# Notion (ANTIEGG 아티클 로드맵 DB)
NOTION_TOKEN=
NOTION_DATABASE_ID=33cffeb1-f498-47a9-abe5-d831328e7d60

# Database (PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/antiegg_newsletter

# Redis (세션 저장)
REDIS_URL=redis://localhost:6379

# Auth
ADMIN_PASSWORD=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3003
PORT=3003
